# Electron reads these values from the process or Windows User environment.
# Never use VITE_* for secrets because Vite embeds them in browser bundles.
MIMO_API_KEY=
MIMO_API_URL=https://api.xiaomimimo.com/v1/chat/completions

# Local Agent Mail feedback synchronizer. Do not prefix with VITE_.
FEEDBACK_NOTIFY_EMAIL=

# Public web form endpoint. This URL is embedded in the browser bundle, so it cannot contain secrets.
VITE_FEEDBACK_ENDPOINT=
