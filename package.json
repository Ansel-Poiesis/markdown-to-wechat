{
  "name": "markdown-to-wechat",
  "version": "2.0.1",
  "description": "本地优先的微信公众号 Markdown 排版与内联 HTML 渲染工具",
  "author": "Ansel",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && npm run build-only",
    "build:electron": "npm run verify && electron-builder --win",
    "build:web": "vite build --outDir docs && npm run check:secrets",
    "preview": "vite preview",
    "render": "tsx --tsconfig tsconfig.node.json scripts/render-wechat.ts",
    "feedback:sync": "tsx --tsconfig tsconfig.node.json scripts/feedback-inbox.ts",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run lint:oxlint && npm run lint:eslint",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "eslint . --cache",
    "lint:fix": "npm run lint:fix:oxlint && npm run lint:fix:eslint",
    "lint:fix:oxlint": "oxlint . --fix",
    "lint:fix:eslint": "eslint . --fix --cache",
    "check:secrets": "node scripts/check-secrets.mjs",
    "verify": "npm run type-check && npm run lint && npm test && npm run build-only && npm run check:secrets",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.0",
    "@vueuse/core": "^14.3.0",
    "codemirror": "^6.0.2",
    "parse5": "8.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "4.23.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "4.1.10",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.mingchuan.markdown-wechat",
    "productName": "微信Markdown排版",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "微信Markdown排版"
    }
  }
}
